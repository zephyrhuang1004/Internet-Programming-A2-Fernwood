# ─────────────────────────────────────────────────────────────────
# Backend env — copy this file to `backend/.env` and fill in the two
# values marked REQUIRED. See README.md → "Environment Variables" for
# a full description of each variable.
# ─────────────────────────────────────────────────────────────────

# REQUIRED — MongoDB Atlas connection string.
# Atlas → Cluster → Connect → Drivers (Python) → copy the URI.
# URL-encode special chars in the password (e.g. `@` → `%40`).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=fernwood-dev

# REQUIRED — HMAC secret for signing JWT access tokens.
# Generate with:  openssl rand -hex 32
# Treat as a password. Use a different value per environment.
JWT_SECRET=change-me-run-openssl-rand-hex-32

# Optional — database name inside the Atlas cluster.
# (Note: the cluster hostname happens to also be called "ip-a2-e-commerce",
#  but the actual database holding all seeded data is "fernwood".)
DB_NAME=fernwood

# Optional — JWT signing algorithm (default: HS256). Don't change.
# JWT_ALG=HS256

# Optional — access token lifetime, in minutes. Auto-refresh handles expiry.
ACCESS_TTL_MIN=30

# Optional — refresh token (httpOnly cookie) lifetime, in days.
REFRESH_TTL_DAYS=30

# Optional — `dev` skips the Secure flag on the refresh cookie so it
# works on http://localhost. Set to `production` when deploying behind HTTPS.
ENV=dev

# Optional — comma-separated front-end origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173
